{
  "name": "agent-credit-rail",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:orchestrator": "pnpm --filter @agent-credit-rail/legasi-orchestrator dev",
    "dev:paywall": "pnpm --filter @agent-credit-rail/paywall-service dev",
    "dev:ui": "pnpm --filter @agent-credit-rail/demo-ui dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "zod": "^3.24.2"
  }
}
